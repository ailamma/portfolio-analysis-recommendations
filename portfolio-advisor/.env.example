# Portfolio Advisor — Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API Key (required for AI analysis)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Data paths (defaults to ./data/ if not set)
UPLOADS_DIR=./data/uploads
PROCESSED_DIR=./data/processed

# Market data refresh interval in seconds (default: 300 = 5 minutes)
MARKET_DATA_REFRESH_SECONDS=300

# Portfolio context (used to calibrate % thresholds)
TASTYTRADE_NET_LIQ=321000
TOS_NET_LIQ=115000

# Claude model to use for analysis
CLAUDE_MODEL=claude-opus-4-6
